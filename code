#include <Servo.h>    // Includes the Servo library so we can control servo motors

// Create four servo objects
Servo servo1;
Servo servo2;
Servo servo3;
Servo servo4;

// Variable that stores the current servo position (0° to 180°)
int pos = 0;

void setup() {

  // Connect each servo object to its Arduino digital pin
  servo1.attach(3);
  servo2.attach(5);
  servo3.attach(6);
  servo4.attach(9);

  // Record the time when the program starts
  // millis() returns the number of milliseconds since the Arduino was powered on
  unsigned long startTime = millis();

  // Keep running the sweep until 2 seconds (2000 milliseconds) have passed
  while (millis() - startTime < 2000) {

    // Move the servos from 0° to 180°
    for (pos = 0; pos <= 180; pos++) {

      // Set all four servos to the current position
      servo1.write(pos);
      servo2.write(pos);
      servo3.write(pos);
      servo4.write(pos);

      // Wait 5 milliseconds before moving to the next position
      // A smaller delay makes the servo move faster
      delay(5);

      // Check if 2 seconds have passed
      // If they have, stop this for loop immediately
      if (millis() - startTime >= 2000)
        break;
    }

    // Move the servos back from 180° to 0°
    for (pos = 180; pos >= 0; pos--) {

      // Set all four servos to the current position
      servo1.write(pos);
      servo2.write(pos);
      servo3.write(pos);
      servo4.write(pos);

      // Wait 5 milliseconds before moving to the next position
      delay(5);

      // Stop the sweep if 2 seconds have passed
      if (millis() - startTime >= 2000)
        break;
    }
  }

  // Move all servos back to the center position (90°)
  servo1.write(90);
  servo2.write(90);
  servo3.write(90);
  servo4.write(90);
}

void loop() {
  // Nothing is placed here, so after setup() finishes,
  // the Arduino does not repeat the sweep.
}
